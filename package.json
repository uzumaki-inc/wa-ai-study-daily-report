{
  "name": "wa-ai-study-daily-report",
  "version": "1.0.0",
  "description": "毎朝9時にSlackへAIニュースの要約を自動投稿するBot",
  "main": "dist/index.js",
  "scripts": {
    "dev": "ts-node src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "post:now": "ts-node src/index.ts",
    "prepare:news": "ts-node src/index.ts prepare",
    "post:slack": "ts-node src/index.ts post",
    "test": "vitest run"
  },
  "keywords": [
    "ai",
    "slack",
    "rss",
    "news"
  ],
  "license": "MIT",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "@slack/webhook": "^7.0.4",
    "rss-parser": "^3.13.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.7.0",
    "vitest": "^4.1.2"
  }
}
